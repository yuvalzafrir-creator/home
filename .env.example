# Local development uses SQLite (a file in prisma/). Copy this to .env.
DATABASE_URL="file:./dev.db"

# Required for listing scoring and the AI copilot. Get one at
# https://console.anthropic.com/ . Leave empty for local UI work — scoring and
# the copilot degrade gracefully without it.
ANTHROPIC_API_KEY=""

# --- Production (Vercel) ---
# Set these in the Vercel project's Environment Variables, NOT in this file:
#   DATABASE_URL       your hosted Postgres connection string (Neon / Vercel Postgres)
#   ANTHROPIC_API_KEY  your Anthropic API key
# The Vercel build swaps the Prisma provider to postgresql automatically
# (see scripts/prepare-prisma-postgres.mjs); local dev/tests stay on SQLite.
